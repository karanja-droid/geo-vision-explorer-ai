# GeoVision AI Miner - Environment Variables Template
# Copy this file to .env and update with your actual values

# Site and API URLs (required for frontend)
VITE_SITE_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8000

# Backend URLs (required for backend)
BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Environment
VITE_ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/geovision
POSTGRES_USER=geovision
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=geovision

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-west-2
S3_BUCKET=geovision-ai-miner-data

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Security
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Feature Flags
ENABLE_FEATURE_STORE=true
ENABLE_AI_INFERENCE=true
ENABLE_ACTIVE_LEARNING=true
ENABLE_DRILL_DATA=true
ENABLE_LIMS_QC=true
ENABLE_ADVANCED_SECURITY=true
ENABLE_DATA_RESIDENCY=false
ENABLE_AUDIT_LOGS=true
ENABLE_MAPLIBRE_FALLBACK=true
ENABLE_USAGE_TRACKING=true

# Feature Store Configuration
FEATURE_STORE_CACHE_TTL=3600
FEATURE_STORE_MAX_CELLS=100000

# AI Configuration
AI_MODEL_PATH=/models/prospectivity
AI_INFERENCE_TIMEOUT=300
AI_MAX_CONCURRENT_JOBS=5

# Data Residency Configuration
DEFAULT_DATA_REGION=us-west-2

# Usage Tracking Configuration
USAGE_TRACKING_INTERVAL=3600
TRIAL_DURATION_DAYS=30

# Audit Configuration
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_EXPORT_INTERVAL_HOURS=24

# Performance Configuration
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_REQUEST_SIZE=100

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Development/Testing
TESTING=false
DEBUG=false