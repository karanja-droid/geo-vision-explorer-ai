{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host :: --port 8080",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:cypress": "cypress open",
    "test:cypress:run": "cypress run",
    "test:all": "npm run test && npm run test:e2e",
    "test:domain-validation": "playwright test tests/e2e/domain-validation.spec.ts",
    "test:e2e:production": "VITE_SITE_URL=https://geo-miner.com VITE_API_BASE_URL=https://api.geo-miner.com playwright test",
    "test:e2e:staging": "VITE_SITE_URL=https://staging.geo-miner.com VITE_API_BASE_URL=https://api.staging.geo-miner.com playwright test",
    "health": "node check-health.js",
    "seed": "tsx scripts/seed-database.ts",
    "seed:sql": "tsx scripts/seed-database.ts --sql-only",
    "generate:data": "tsx -e \"import('./src/utils/dataExport.ts').then(m => m.dataExporter.generateDataFiles())\"",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "data:stats": "tsx -e \"import('./src/utils/mockData.ts').then(m => console.log('📊 Data Statistics:', JSON.stringify(m.dataStatistics, null, 2)))\"",
    "playwright:install": "playwright install",
    "prebuild": "npm run generate:sitemap",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org geovision --project ai-miner ./dist && sentry-cli sourcemaps upload --org geovision --project ai-miner ./dist"
  },
