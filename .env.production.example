# GeoMiner Production Environment Variables
# Copy this file to .env.production and update with your actual values

# Application Configuration
NODE_ENV=production
VITE_APP_NAME="GeoMiner - AI Geological Intelligence"
VITE_APP_URL="https://geo-miner.com"
VITE_COMPANY_NAME="ProspectIQ Labs LLC"
VITE_DOMAIN="geo-miner.com"

# Supabase Configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database Configuration
DATABASE_URL="postgresql://username:password@your-rds-endpoint:5432/geominer"

# Redis Configuration
REDIS_URL="redis://your-elasticache-endpoint:6379"

# Mapbox Configuration
VITE_MAPBOX_ACCESS_TOKEN="pk.your-mapbox-access-token"

# AWS Configuration
AWS_REGION="us-west-2"
AWS_S3_BUCKET="geominer-assets-prod"
AWS_CLOUDFRONT_DISTRIBUTION_ID="your-cloudfront-distribution-id"

# Stripe Configuration (for payments)
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_your-stripe-publishable-key"
STRIPE_SECRET_KEY="sk_live_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Email Configuration
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@geo-miner.com"

# SMS Configuration (for alerts)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# AI/ML Configuration
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
OPENAI_API_KEY="sk-your-openai-api-key"

# Monitoring Configuration
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_ENVIRONMENT="production"

# Security Configuration
JWT_SECRET="your-jwt-secret-key"
ENCRYPTION_KEY="your-encryption-key"

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_MONITORING=true
VITE_ENABLE_ERROR_REPORTING=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"

# CORS Configuration
CORS_ORIGIN="https://geo-miner.com,https://www.geo-miner.com"

# Session Configuration
SESSION_SECRET="your-session-secret"
SESSION_TIMEOUT=3600000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf,text/csv"

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_INTERVAL=30000